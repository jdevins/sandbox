{
  "name": "sandbox-server",
  "version": "0.1.0",
  "private": true,
  "description": "Prototype-oriented Express server hosting multiple unrelated apps, managed by Claude.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test",
    "setup:hooks": "git config core.hooksPath .hooks",
    "markitdown:setup": "node apps/markitdown/lib/setup.js",
    "markitdown:build": "node apps/markitdown/lib/build.js"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "node-cron": "^4.2.1"
  }
}
