<%- include('partials/head', { title }) %>

  <header class="site">
    <h1>🧪 Sandbox Server</h1>
    <span class="muted"><%= apps.length %> app<%= apps.length === 1 ? '' : 's' %> · uptime <%= Math.floor(process.uptime()) %>s</span>
  </header>

  <div class="toolbar row spread">
    <div class="row">
      <button class="btn" data-action="discover">↻ Rescan apps/</button>
      <a class="btn" href="/healthz" target="_blank">Health JSON</a>
    </div>
  </div>

  <% if (!apps.length) { %>
    <div class="empty">
      No apps yet. Create <code>apps/&lt;name&gt;/index.js</code> exporting
      <code>meta</code> + <code>createApp(ctx)</code>, then click <em>Rescan</em>.
    </div>
  <% } else { %>
    <div class="grid">
      <% apps.forEach((a) => { const h = health[a.name] || {}; %>
        <div class="card" data-app="<%= a.name %>">
          <div class="row spread">
            <h2><%= a.meta.name || a.name %></h2>
            <span class="badge <%= a.status %>" data-status><%= a.status %></span>
          </div>
          <div class="desc"><%= a.meta.description || '—' %></div>
          <div class="meta">
            v<%= a.meta.version %><% if (h.detail) { %> · <%= h.detail %><% } %>
          </div>
          <div class="row" style="margin-top:14px">
            <a class="btn primary" href="/apps/<%= a.name %>" target="_blank">Open ↗</a>
            <button class="btn" data-action="restart" data-name="<%= a.name %>">Restart</button>
            <% if (a.status === 'running') { %>
              <button class="btn" data-action="stop" data-name="<%= a.name %>">Stop</button>
            <% } else { %>
              <button class="btn" data-action="start" data-name="<%= a.name %>">Launch</button>
            <% } %>
            <button class="btn" data-action="test" data-name="<%= a.name %>">Test</button>
            <button class="btn" data-action="deploy" data-name="<%= a.name %>">Deploy</button>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

<%- include('partials/foot') %>
